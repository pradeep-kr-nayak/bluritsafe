{
  "manifest_version": 3,
  "name": "BlurItSafe",
  "version": "0.1.0",
  "description": "Blur text, tables, images, and other page sections before taking screenshots.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "downloads", "scripting"],
  "action": {
    "default_title": "BlurItSafe",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
